<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LinkWorld - Global Seamless Communication</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;900&display=swap" rel="stylesheet">
  <style>
    body { 
      font-family: 'Inter', system-ui, sans-serif; 
      scroll-behavior: smooth; 
    }
    .hero-bg { 
      background: linear-gradient(135deg, #fff7ed 0%, #f3e8ff 100%); 
    }
    .linkworld-title {
      font-family: 'Orbitron', sans-serif;
      font-size: 5.8rem;
      font-weight: 900;
      letter-spacing: -0.03em;
      line-height: 1.02;
    }
    .logo-container {
      background: rgba(255, 255, 255, 0.95);
      border-radius: 9999px;
      padding: 8px;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }
    .section { padding: 110px 0; }
    .nav-link { transition: all 0.3s; }
    .nav-link:hover { color: #f97316; }
    .support-btn:hover {
      transform: scale(1.12);
      box-shadow: 0 0 20px rgba(249, 115, 22, 0.6);
    }
  </style>
</head>
<body class="bg-white text-gray-900">

  <!-- Navbar -->
  <nav class="fixed top-0 left-0 right-0 bg-white/90 backdrop-blur-md z-50 border-b">
    <div class="max-w-7xl mx-auto flex items-center justify-between px-8 py-5">
      <div class="flex items-center gap-3">
        <div class="logo-container">
          <img src="d:\20260401-224553.png" 
               alt="LinkWorld Logo" 
               class="h-10 w-10">
        </div>
      </div>
      
      <div class="hidden md:flex items-center gap-8 text-sm font-medium">
        <a href="#why" class="nav-link">Why LinkWorld</a>
        <a href="#how" class="nav-link">How it Works</a>
        <a href="#features" class="nav-link">Key Features</a>
        <a href="#contact" class="nav-link">Contact Us</a>
      </div>
      
      <div class="flex items-center gap-4">
      
        <button onclick="alert('Customer Support Coming Soon!\nYou can contact us via Telegram or Email.')"
                class="support-btn w-11 h-11 flex items-center justify-center bg-white border-2 border-orange-400 rounded-2xl text-orange-500 hover:bg-orange-50 transition-all shadow-md">
          <i class="fa-solid fa-headset text-2xl"></i>
        </button>
        
        <button onclick="goToLogin()" 
                class="bg-gradient-to-r from-orange-400 to-purple-500 text-white px-7 py-3 rounded-2xl font-medium hover:shadow-lg transition">
          Get Started
        </button>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="hero-bg min-h-screen flex items-center pt-20">
    <div class="max-w-5xl mx-auto text-center px-6">
      <h1 class="linkworld-title text-gray-900 mb-6">LinkWorld</h1>
      
      <p class="max-w-2xl mx-auto text-[1.35rem] text-gray-600 leading-relaxed mb-16">
        A blockchain-powered communication platform<br>
        Making mobile data and calls affordable and convenient worldwide.
      </p>

      <div class="max-w-2xl mx-auto mt-8">
        <div class="bg-white rounded-3xl shadow-2xl p-2 flex items-center">
          <div class="flex-1 flex items-center px-8 py-5">
            <i class="fa-solid fa-magnifying-glass text-gray-400 text-2xl mr-4"></i>
            <input type="text" id="search-input" placeholder="Search regions, destinations, plans..." 
                   class="flex-1 bg-transparent outline-none text-lg placeholder-gray-400">
          </div>
          <button onclick="alert('Search feature coming soon ~ Supporting 150+ regions and Starlink')" 
                  class="bg-gradient-to-r from-orange-400 to-purple-500 text-white font-semibold px-12 py-5 rounded-3xl hover:scale-105 transition">
            Search
          </button>
        </div>
      </div>

      <div class="mt-20">
        <button onclick="goToLogin()" 
                class="bg-black text-white px-10 py-5 rounded-2xl text-lg font-medium hover:bg-gray-800 transition">
          Start Using Now →
        </button>
      </div>
    </div>
  </section>

  <!-- Why LinkWorld -->
  <section id="why" class="section bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-5xl font-bold text-center mb-16">Why Choose LinkWorld?</h2>
      <div class="grid md:grid-cols-3 gap-10">
        <div class="bg-white p-10 rounded-3xl shadow">
          <h3 class="text-2xl font-semibold mb-4">💸 High Roaming Costs?</h3>
          <p class="text-gray-600">Say goodbye to expensive traditional roaming plans.</p>
        </div>
        <div class="bg-white p-10 rounded-3xl shadow">
          <h3 class="text-2xl font-semibold mb-4">📍 Cross-Border Inconvenience?</h3>
          <p class="text-gray-600">No need to buy local SIM cards or roaming packages.</p>
        </div>
        <div class="bg-white p-10 rounded-3xl shadow">
          <h3 class="text-2xl font-semibold mb-4">🔒 Complicated KYC?</h3>
          <p class="text-gray-600">No identity verification needed — just your wallet address.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section id="how" class="section">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h2 class="text-5xl font-bold mb-6">How It Works - Pay After Use</h2>
      <p class="text-xl text-gray-600 mb-16">Three simple steps to global connectivity</p>
      <div class="grid md:grid-cols-3 gap-12">
        <div class="text-center">
          <div class="w-20 h-20 mx-auto bg-orange-100 rounded-2xl flex items-center justify-center text-4xl mb-6">1</div>
          <h3 class="text-2xl font-semibold mb-3">Connect Wallet</h3>
          <p class="text-gray-600">Link your wallet and email, deposit a small security bond</p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 mx-auto bg-purple-100 rounded-2xl flex items-center justify-center text-4xl mb-6">2</div>
          <h3 class="text-2xl font-semibold mb-3">Choose Region</h3>
          <p class="text-gray-600">Select your destination, get a virtual number and connect instantly</p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 mx-auto bg-blue-100 rounded-2xl flex items-center justify-center text-4xl mb-6">3</div>
          <h3 class="text-2xl font-semibold mb-3">Pay After Use</h3>
          <p class="text-gray-600">Auto settlement at month-end or manual anytime. Pay within 2 weeks</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Features -->
  <section id="features" class="section bg-gray-50">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h2 class="text-5xl font-bold mb-16">Key Features</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-3xl shadow">
          <h3 class="text-2xl font-semibold mb-4">Pay After Use</h3>
          <p class="text-gray-600">Use first, pay later. Stop service anytime and settle manually.</p>
        </div>
        <div class="bg-white p-8 rounded-3xl shadow">
          <h3 class="text-2xl font-semibold mb-4">No KYC Required</h3>
          <p class="text-gray-600">Wallet address + security deposit is all you need.</p>
        </div>
        <div class="bg-white p-8 rounded-3xl shadow">
          <h3 class="text-2xl font-semibold mb-4">Global Seamless Roaming</h3>
          <p class="text-gray-600">Switch regions effortlessly with eSIM or virtual numbers.<br>
          <span class="text-orange-500 font-medium">Support Starlink</span></p>
        </div>
        <div class="bg-white p-8 rounded-3xl shadow">
          <h3 class="text-2xl font-semibold mb-4">Secure & Reliable</h3>
          <p class="text-gray-600">Smart contracts audited by CertiK/OpenZeppelin. Data via Chainlink.</p>
        </div>
        <div class="bg-white p-8 rounded-3xl shadow">
          <h3 class="text-2xl font-semibold mb-4">Low Cost</h3>
          <p class="text-gray-600">Deployed on Ethereum L2 + BNB Chain. Only 2.5% service fee.</p>
        </div>
        <div class="bg-white p-8 rounded-3xl shadow">
          <h3 class="text-2xl font-semibold mb-4">Flexible Settlement</h3>
          <p class="text-gray-600">Billing stops on the last day of the month. Bill sent on the 2nd.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Us -->
  <section id="contact" class="section bg-black text-white">
    <div class="max-w-4xl mx-auto text-center px-6">
      <h2 class="text-5xl font-bold mb-8">Ready to Experience Global Connectivity?</h2>
      <p class="text-xl text-gray-300 mb-12">Contact us for more information or to join our test group</p>
      
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a href="mailto:linkworld@outlook.com" 
           class="bg-white text-black px-10 py-5 rounded-2xl font-medium hover:bg-gray-100 transition flex items-center justify-center gap-3">
          <i class="fa-solid fa-envelope"></i>
          Send Email
        </a>
        <a href="https://t.me/LinkWorldone" 
           class="border border-white px-10 py-5 rounded-2xl font-medium hover:bg-white/10 transition flex items-center justify-center gap-3">
          <i class="fa-solid fa-telegram"></i>
          Join Telegram
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-gray-900 text-gray-400 py-16">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="text-sm">© 2026 LinkWorld</p>
      <p class="text-xs mt-4 text-gray-500">Decentralized Communication Platform • Compliant with Global Regulations</p>
    </div>
  </footer>


  <div id="login-page" class="hidden fixed inset-0 bg-white z-[100] overflow-auto">
    <div class="min-h-screen flex items-center justify-center px-6 py-12 bg-gradient-to-br from-orange-50 to-purple-50">
      <div class="max-w-md w-full bg-white rounded-3xl shadow-2xl p-10">
        <div class="flex justify-between items-center mb-8">
          <h2 class="text-3xl font-bold text-gray-900">Welcome to LinkWorld</h2>
          <button onclick="goBackToHome()" class="text-gray-400 hover:text-gray-600">
            <i class="fa-solid fa-xmark text-2xl"></i>
          </button>
        </div>

 
        <div id="step-input" class="space-y-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Wallet Address</label>
            <input id="wallet-input" type="text" placeholder="0x1234...abcd" 
                   class="w-full px-5 py-4 border border-gray-300 rounded-2xl focus:outline-none focus:border-orange-500">
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Email Address</label>
            <div class="flex gap-3">
              <input id="email-input" type="email" placeholder="you@example.com" 
                     class="flex-1 px-5 py-4 border border-gray-300 rounded-2xl focus:outline-none focus:border-orange-500">
              <button onclick="sendCode()" 
                      class="bg-orange-500 hover:bg-orange-600 text-white px-6 py-4 rounded-2xl font-medium whitespace-nowrap">
                Get Code
              </button>
            </div>
          </div>

          <div id="otp-section" class="hidden">
            <label class="block text-sm font-medium text-gray-700 mb-3">Verification Code</label>
            <input id="otp-input" type="text" maxlength="6" placeholder="123456" 
                   class="w-full text-center text-3xl tracking-widest px-6 py-5 border border-gray-300 rounded-2xl focus:outline-none focus:border-purple-500">
            <p id="otp-hint" class="text-xs text-gray-500 mt-2 text-center">Enter the 6-digit code sent to your email</p>
          </div>

          <button onclick="verifyCode()" id="verify-btn"
                  class="w-full bg-gradient-to-r from-orange-400 to-purple-500 text-white py-4 rounded-2xl font-semibold text-lg mt-6 hidden">
            Verify & Login
          </button>
        </div>


        <div id="success-screen" class="hidden text-center py-12">
          <div class="w-20 h-20 mx-auto bg-green-100 rounded-full flex items-center justify-center mb-6">
            <i class="fa-solid fa-check text-5xl text-green-600"></i>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-2">Login Successful!</h3>
          <p class="text-gray-600 mb-8">Welcome back to LinkWorld</p>
          <button onclick="goBackToHome()" 
                  class="w-full bg-black text-white py-4 rounded-2xl font-medium">
            Back to Home
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    function goToLogin() {
      document.getElementById('login-page').classList.remove('hidden');
      document.getElementById('step-input').classList.remove('hidden');
      document.getElementById('success-screen').classList.add('hidden');
      document.getElementById('otp-section').classList.add('hidden');
      document.getElementById('verify-btn').classList.add('hidden');
    }

    function goBackToHome() {
      document.getElementById('login-page').classList.add('hidden');
      document.getElementById('wallet-input').value = '';
      document.getElementById('email-input').value = '';
      document.getElementById('otp-input').value = '';
    }

    function sendCode() {
      const email = document.getElementById('email-input').value.trim();
      if (!email) {
        alert("Please enter your email address");
        return;
      }
      alert(`Verification code sent to ${email}\n(Demo: use 123456)`);
      document.getElementById('otp-section').classList.remove('hidden');
      document.getElementById('verify-btn').classList.remove('hidden');
    }

    function verifyCode() {
      const code = document.getElementById('otp-input').value.trim();
      if (code === "123456") {
        document.getElementById('step-input').classList.add('hidden');
        document.getElementById('success-screen').classList.remove('hidden');
      } else {
        alert("Incorrect code. Demo: please enter 123456");
      }
    }

    document.getElementById('search-input').addEventListener('keypress', function(e) {
      if (e.key === 'Enter') {
        alert('Search feature coming soon ~ Supporting 150+ regions and Starlink');
      }
    });
  </script>
</body>
</html>
